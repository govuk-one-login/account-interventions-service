{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "lib": ["es2022", "dom"],
    "target": "es2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "declaration": true,
    "rootDir": "../.."
  },
  "include": ["src/index.ts", "../../src/data-types/api-schemas-v2.ts", "../../src/data-types/intervention-name.ts"],
  "exclude": ["dist"]
}
