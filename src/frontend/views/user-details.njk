{% extends "base.njk" %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% block head %}
  {{ super() }}
  <style>
    .ais-timeline-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0 10px; /* vertical gap between rows */
    }
    .ais-timeline-table td {
      vertical-align: top;
    }
    .ais-summary-list--no-last-border .govuk-summary-list__row:last-child {
      border-bottom: none;
    }
    .ais-timeline__card {
      border-style: solid;
      border-width: 1px;
      border-radius: 6px;
      border-color: #d1d9e0;
    }
    .ais-timeline__card-header {
      display: flex;
      align-items: baseline;
      gap: 10px;
      flex-wrap: wrap;
      border-bottom: 1px solid #d1d9e0;
      padding: 15px 20px;
      background-color: #818b981f;
    }
    .ais-timeline__timestamp {
      color: #505a5f;
    }
    .ais-timeline__card-body {
      padding: 0 20px;
      border-bottom: 1px solid #d1d9e0;
    }
    .ais-timeline__card-body:last-child {
      border-bottom: none;
    }
    /* State tag cells — padding-top aligns tag centre with card header centre. Card header: 15px padding-top + 20px
   line-height (govuk-body-s 16px * 1.25) → centre at 25px. govuk-tag ~22px tall → padding-top = 25 - 11 = 14px. */
    .ais-intervention-table__cell {
      padding: 14px 10px;
      text-align: center;
      vertical-align: top;
      white-space: nowrap;
      position: relative;
    }
    /* Vertical connector line through state cells. Rows are newest→oldest top→bottom: START → line in top half only
   (connects up to END row above) END → line in bottom half only (connects down to START row below) CONTINUE → full
   height line absent → no line */
    .ais-intervention-table__cell::before {
      content: '';
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      width: 3px;
      /* 5px dash / 5px gap = 10px period, matching the border-spacing row gap exactly. background-position-y: -10px anchors
   the gradient 10px above the element's top (i.e. at the row gap above), so adjacent cells always start in phase. */
      background-image: linear-gradient(#aaaaaa 50%, transparent 50%);
      background-size: 2px 10px;
      background-position-y: -10px;
      background-repeat: repeat-y;
    }
    .ais-intervention-table__cell--start::before {
      top: -10px;
      height: 35px; /* 10px gap above + 25px to tag centre */
    }
    .ais-intervention-table__cell--end::before {
      top: 25px;
      bottom: -10px;
    }
    .ais-intervention-table__cell--continue::before {
      top: -10px;
      bottom: -10px;
    }
    .ais-intervention-table__cell--absent::before {
      display: none;
    }
  </style>
{% endblock %}
{% block content %}
  {{ govukBackLink({ text: "Back", href: stagePrefix + "/" }) }}
  {% if messageSent %}
    {{ govukNotificationBanner({
      type: "success",
      html: "<p class=\"govuk-body\">TxMA message sent for user <strong>" + userId + "</strong>.</p>"
    }) }}
  {% endif %}
  <h1 class="govuk-heading-xl">Account Status</h1>
  <p class="govuk-body">User ID:
    <strong>{{ userId }}</strong>
  </p>
  <h2 class="govuk-heading-m">Active Interventions</h2>
  {% if accountStatus %}
    {% if accountStatus.interventions.length %}
      {% set rows = [] %}
      {% for intervention in accountStatus.interventions %}
        {% set rows = rows.concat([{
          key: { text: intervention.name },
          value: { html: '<strong class="govuk-tag govuk-tag--red">ACTIVE</strong>' }
        }]) %}
      {% endfor %}
      {{ govukSummaryList({ rows: rows }) }}
    {% else %}
      <p class="govuk-body">There are no active interventions on this account.</p>
    {% endif %}
  {% else %}
    <p class="govuk-body">No account found for this identifier.</p>
  {% endif %}
  <h2 class="govuk-heading-m govuk-!-margin-top-6 govuk-!-margin-bottom-0">History</h2>
  {% if transactions and transactions.length %}
    <table class="ais-timeline-table" aria-label="Intervention history">
      <thead>
        <tr>
          <th scope="col" style="border-bottom:2px solid #0b0c0c; width:100%;"></th>
          {% for name in allInterventionNames %}
            <th
              scope="col"
              class="govuk-body-s"
              style="font-size:16px; padding:0 1px 6px; text-align:center; border-bottom:2px solid #0b0c0c; font-weight: 100">
              {{ name | replace("_", " ") }}
            </th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>
        {# Current state row — sits above the history, shows ACTIVE tag for each currently active intervention.
                                                                                           Uses --end so the dashed line runs downward from the tag into the history below. #}
        <tr>
          <td style="padding: 0 0 10px 0; vertical-align: top; box-shadow: 0 2px 0 #0b0c0c;">
            <div style="padding: 14px 20px; font-weight: bold;" class="govuk-body-m govuk-!-margin-bottom-0">Current state</div>
          </td>
          {% for name in allInterventionNames %}
            {% set isActive = false %}
            {% if accountStatus %}
              {% for intervention in accountStatus.interventions %}
                {% if intervention.name == name %}
                  {% set isActive = true %}
                {% endif %}
              {% endfor %}
            {% endif %}
            <td
              class="ais-intervention-table__cell ais-intervention-table__cell--{{ 'end' if isActive else 'absent' }}"
              style="box-shadow: 0 2px 0 #0b0c0c;">
              {% if isActive %}
                <strong class="govuk-tag govuk-tag--red" style="font-size:16px; position:relative; z-index:1;">ACTIVE</strong>
              {% endif %}
            </td>
          {% endfor %}
        </tr>
        {% for transaction in transactions %}
          <tr>
            {# Card cell #}
            <td style="vertical-align:top; padding:0 10px 10px 0;">
              <div class="ais-timeline__card">
                <div class="ais-timeline__card-header">
                  <span class="govuk-body-s govuk-!-margin-bottom-0">{{ transaction.requesterId }}</span>
                  <span class="ais-timeline__timestamp govuk-body-s govuk-!-margin-bottom-0">{{ transaction.sentAtFormatted }}</span>
                </div>
                <div class="ais-timeline__card-body">
                  {% set detailRows = [
                    { key: { text: "Component" }, value: { text: transaction.componentId } },
                    { key: { text: "Reason" },    value: { text: transaction.interventionReason } }
                  ] %}
                  {% if transaction.interventionCode %}
                    {% set detailRows = detailRows.concat([{ key: { text: "Code" }, value: { text: transaction.interventionCode } }]) %}
                  {% endif %}
                  {% if transaction.originatingComponent %}
                    {% set detailRows = detailRows.concat([{ key: { text: "Originating Component" }, value: { text: transaction.originatingComponent } }]) %}
                  {% endif %}
                  {% if transaction.originatorReferenceId %}
                    {% set detailRows = detailRows.concat([{ key: { text: "Originator Reference ID" }, value: { text: transaction.originatorReferenceId } }]) %}
                  {% endif %}
                  {{ govukSummaryList({ classes: "govuk-!-margin-bottom-0 govuk-!-font-size-16 ais-summary-list--no-last-border", rows: detailRows }) }}
                </div>
              </div>
            </td>
            {# State tag cells #}
            {% for name in allInterventionNames %}
              {% set lineState = transaction.activeInterventions[name] %}
              <td class="ais-intervention-table__cell ais-intervention-table__cell--{{ lineState | lower if lineState else 'absent' }}">
                {% set stateForName = null %}
                {% for event in transaction.interventionEvents %}
                  {% if event.interventionName == name %}
                    {% set stateForName = event.interventionState %}
                  {% endif %}
                {% endfor %}
                {% if stateForName %}
                  {% if stateForName == "ACTIVE" %}
                    {% set tagColour = "red" %}
                  {% elif stateForName == "MITIGATED" %}
                    {% set tagColour = "green" %}
                  {% elif stateForName == "REMOVED" %}
                    {% set tagColour = "grey" %}
                  {% elif stateForName == "SUPERSEDED" %}
                    {% set tagColour = "orange" %}
                  {% elif stateForName == "IGNORED" %}
                    {% set tagColour = "yellow" %}
                  {% else %}
                    {% set tagColour = "blue" %}
                  {% endif %}
                  <strong class="govuk-tag govuk-tag--{{ tagColour }}" style="font-size:16px; position:relative; z-index:1;">{{ stateForName }}</strong>
                {% endif %}
              </td>
            {% endfor %}
          </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <p class="govuk-body-s">No history available for this account.</p>
  {% endif %}
  {% if aisSendTxMA %}
    <form method="post" action="{{ stagePrefix }}/send" class="govuk-!-padding-top-6">
      <input type="hidden" name="userId" value="{{ userId }}"/>{{ govukButton({ text: "Send TxMA Message" }) }}
    </form>
  {% endif %}
{% endblock %}
